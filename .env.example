# Trading 212 MCP Server — environment variables
# Copy to .env and fill in values (or use a /config/config.json mount instead)

# Credentials from the Trading 212 app: Settings > API (Beta).
# The secret is shown only once at generation time.
TRADING212_API_KEY=your-api-key-here
TRADING212_API_SECRET=your-api-secret-here

# Environment switch: "true" = LIVE (real money), anything else = demo/paper.
# Defaults to false (paper) when unset.
TRADING212_LIVE=false

# Optional: override server bind settings
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000

# Optional: override config file directory for the docker-compose volume mount
# TRADING212_CONFIG_DIR=~/.config/trading212-mcp
